# ============================================
# G WORKSPACE — Root .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build outputs ----
dist/
build/
.next/
out/

# ---- Environment variables ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- OS generated files ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---- IDE / Editor ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- Testing ----
coverage/
.nyc_output/

# ---- Package lock files ----
# Keep package-lock.json for reproducible installs
# (uncomment below line if you want to exclude them)
# package-lock.json

# ---- Development artifacts ----
implementation_plan.md
walkthrough.md
synchronization_analysis.md

# ---- Misc ----
*.tgz
.cache/
.parcel-cache/
